# =============================================================================
# Docker Infrastructure - Environment Configuration
# =============================================================================
# Copy this file to .env and replace all passwords before deploying.
#   cp .env.example .env
#   openssl rand -base64 32   # use this to generate each password
# =============================================================================

# ---------------------------------------------------------------------------
# Database Passwords
# ---------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=Ch@ngeMe_R00t!
POSTGRES_PASSWORD=Ch@ngeMe_DB!
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=Ch@ngeMe_R00t!
REDIS_PASSWORD=Ch@ngeMe_Redis!

# Replication
# ---------------------------------------------------------------------------
# Database Management
# ---------------------------------------------------------------------------
PMA_HOST=mysql
PMA_PORT=3306
UPLOAD_LIMIT=256M
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=Ch@ngeMe_PgAdmin!
RI_APP_PORT=5540

# ---------------------------------------------------------------------------
# RabbitMQ
# ---------------------------------------------------------------------------
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=Ch@ngeMe_Rabbit!

# ---------------------------------------------------------------------------
# MinIO
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=Ch@ngeMe_MinIO!
MINIO_DOMAIN=storage.example.com
MINIO_SERVER_URL=http://minio:9000
MINIO_BROWSER_REDIRECT_URL=http://minio:9001

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=Ch@ngeMe_Grafana!

# ---------------------------------------------------------------------------
# CrowdSec (profile: production)
# ---------------------------------------------------------------------------
CROWDSEC_ENROLL_KEY=
CROWDSEC_AGENT_USER=admin
CROWDSEC_AGENT_PASSWORD=Ch@ngeMe_CrowdSec!

# ---------------------------------------------------------------------------
# Arcane (profile: production)
# ---------------------------------------------------------------------------
ARCANE_JWT_SECRET=Ch@ngeMe_Arcane_JWT!
ARCANE_ENCRYPTION_KEY=Ch@ngeMe_Arcane_EncryptionKey_32chars

# ---------------------------------------------------------------------------
# Cloudflare (for NPM SSL)
# ---------------------------------------------------------------------------
CLOUDFLARE_EMAIL=admin@example.com
CLOUDFLARE_API_TOKEN=

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=infrastructure
TZ=UTC

# ---------------------------------------------------------------------------
# Backup
# ---------------------------------------------------------------------------
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
